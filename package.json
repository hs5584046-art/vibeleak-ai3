    "@types/react-dom": "19.1.6",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.31.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "26.1.0",
    "postcss": "8.5.6",
