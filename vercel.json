{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci --no-audit --no-fund",
  "buildCommand": "npm run typecheck && npm run build",
  "crons": [
    {
      "path": "/api/cron/autopilot",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/cron/career-agent",
      "schedule": "45 5 * * *"
    }
  ]
}