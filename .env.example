# Public application settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@vibelytix.lol
NEXT_PUBLIC_UPI_ID=YOUR_UPI_ID@bank
NEXT_PUBLIC_UPI_NAME=VibeLytix

# Supabase — MARKED PLACEHOLDERS
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY

# Revenue operations
ADMIN_EMAILS=owner@example.com
PAYMENT_TOKEN_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
PAYMENT_NOTIFICATION_EMAIL=owner@example.com

# Optional transactional email through Resend HTTP API
RESEND_API_KEY=
EMAIL_FROM=VibeLytix <reports@vibelytix.lol>


# Optional affiliate destinations — MARKED PLACEHOLDERS.
# Leave blank to use the matching internal educational guide instead.
AFFILIATE_RELATIONSHIP_BOOK=
AFFILIATE_RELATIONSHIP_COURSE=
AFFILIATE_CAREER_BOOK=
AFFILIATE_CAREER_COURSE=
AFFILIATE_GROWTH_BOOK=
AFFILIATE_GROWTH_COURSE=

# Generate with: openssl rand -base64 32
CRON_SECRET=

# Random 32+ character IndexNow key. Also expose it at /<key>.txt before enabling.
INDEXNOW_KEY=

# Optional official external distribution APIs
# Mastodon: create an application/access token for your own account
MASTODON_BASE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# Bluesky: use an app password, not the main account password
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# DEV Community API key (Settings > Extensions)
DEVTO_API_KEY=

# WordPress REST API with an Application Password
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# Optional first-party performance data (read-only OAuth access tokens)
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
GOOGLE_ANALYTICS_ACCESS_TOKEN=
GA4_PROPERTY_ID=

# Recommended for unattended Google token renewal.
# After this one-time OAuth grant, Search Console and GA4 refresh automatically.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
